{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "devdock",
  "version": "0.1.3",
  "identifier": "com.wangqinghua.devdock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "devdock",
        "width": 1180,
        "height": 720,
        "minWidth": 1180,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENGNjM1RDZDNThGM0MxODMKUldTRHdmTlliRjFqeitCLzlHTDQwMVhTVmZmZzhLOFY5Y29ZckJkRkI4R1o0U1lPL0ZDVGpSY3oK",
      "endpoints": [
        "https://github.com/wangzong0427/DevDock/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
